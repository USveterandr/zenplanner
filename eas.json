{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "applicationArchivePath": "android-twa/app/build/outputs/apk/**/*.apk"
      },
      "config": "production.yml"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "applicationArchivePath": "android-twa/app/build/outputs/apk/**/*.apk"
      },
      "config": "production.yml"
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle",
        "applicationArchivePath": "android-twa/app/build/outputs/bundle/release/app-release.aab"
      },
      "config": "production.yml"
    }
  },
  "submit": {
    "production": {}
  }
}
